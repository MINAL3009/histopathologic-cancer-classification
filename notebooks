      "source": [
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "#   GRAD-CAM — Clean Fix for Wrapped ResNet50\n",
        "# ══════════════════════════════════════════════════════════════════════════════\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import tensorflow as tf\n",
        "import cv2\n",
        "\n",
        "# ── Step 1: Build a clean end-to-end model for Grad-CAM ──────────────────────\n",
        "\n",
        "inner_resnet = resnet_model.get_layer('resnet50')\n",
        "\n",
        "# Build fresh unwrapped model using inner_resnet's own input\n",
        "img_input    = inner_resnet.input                                      # (None,224,224,3)\n",
        "conv_output  = inner_resnet.get_layer('conv5_block3_out').output       # last conv layer\n",
        "\n",
        "# Build conv-only model (input → last conv)\n",
        "conv_model   = tf.keras.Model(inputs=img_input, outputs=conv_output)\n",
        "\n",
        "# Build classifier head model (GAP → Dense layers)\n",
        "gap_input    = tf.keras.Input(shape=conv_output.shape[1:])             # (7,7,2048)\n",
        "x            = resnet_model.get_layer('global_average_pooling2d')(gap_input)\n",
        "x            = resnet_model.get_layer('dense')(x)\n",
        "x            = resnet_model.get_layer('batch_normalization')(x)\n",
        "x            = resnet_model.get_layer('dropout')(x)\n",
        "x            = resnet_model.get_layer('dense_1')(x)\n",
        "x            = resnet_model.get_layer('dropout_1')(x)\n",
        "x            = resnet_model.get_layer('dense_2')(x)\n",
        "head_model   = tf.keras.Model(inputs=gap_input, outputs=x)\n",
        "\n",
        "print(\"✅ conv_model  input  :\", conv_model.input.shape)\n",
        "print(\"✅ conv_model  output :\", conv_model.output.shape)\n",
        "print(\"✅ head_model  input  :\", head_model.input.shape)\n",
        "print(\"✅ head_model  output :\", head_model.output.shape)\n",
        "\n",
        "\n",
        "# ── Step 2: Grad-CAM function ─────────────────────────────────────────────────\n",
        "\n",
        "def make_gradcam_heatmap(img_array, conv_model, head_model):\n",
        "    \"\"\"\n",
        "    img_array: shape (1, 224, 224, 3), float32, normalized 0-1\n",
        "    \"\"\"\n",
        "    with tf.GradientTape() as tape:\n",
        "        conv_out   = conv_model(img_array, training=False)  # (1,7,7,2048)\n",
        "        tape.watch(conv_out)\n",
        "        prediction = head_model(conv_out, training=False)   # (1,1)\n",
        "        loss       = prediction[:, 0]\n",
        "\n",
        "    grads        = tape.gradient(loss, conv_out)            # (1,7,7,2048)\n",
        "    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))    # (2048,)\n",
        "\n",
        "    conv_out     = conv_out[0]                              # (7,7,2048)\n",
        "    heatmap      = conv_out @ pooled_grads[..., tf.newaxis] # (7,7,1)\n",
        "    heatmap      = tf.squeeze(heatmap)                      # (7,7)\n",
        "    heatmap      = tf.maximum(heatmap, 0)\n",
        "    heatmap      = heatmap / (tf.reduce_max(heatmap) + 1e-8)\n",
        "\n",
        "    return heatmap.numpy()\n",
        "\n",
        "\n",
        "# ── Step 3: Overlay function ──────────────────────────────────────────────────\n",
        "\n",
        "def overlay_gradcam(original_img, heatmap, alpha=0.4):\n",
        "    \"\"\"original_img: uint8 (224,224,3)\"\"\"\n",
        "    heatmap_resized = cv2.resize(heatmap, (224, 224))\n",
        "    heatmap_colored = cv2.applyColorMap(np.uint8(255 * heatmap_resized), cv2.COLORMAP_JET)\n",
        "    heatmap_colored = cv2.cvtColor(heatmap_colored, cv2.COLOR_BGR2RGB)\n",
        "    overlayed       = cv2.addWeighted(original_img, 1 - alpha,\n",
        "                                      heatmap_colored, alpha, 0)\n",
        "    return overlayed\n",
        "\n",
        "\n",
        "# ── Step 4: Run Grad-CAM on test samples ─────────────────────────────────────\n",
        "\n",
        "def run_gradcam(model, conv_model, head_model, test_gen, num_samples=8):\n",
        "\n",
        "    test_gen.reset()\n",
        "    class_names = list(test_gen.class_indices.keys())\n",
        "    filepaths   = test_gen.filepaths\n",
        "    true_labels = test_gen.labels\n",
        "\n",
        "    # Get predictions from original model\n",
        "    probs = model.predict(test_gen, steps=len(test_gen), verbose=0).flatten()\n",
        "    preds = (probs >= 0.5).astype(int)\n",
        "\n",
        "    # Pick 4 correct + 4 incorrect\n",
        "    correct_idx   = np.where(preds == true_labels)[0][:num_samples // 2]\n",
        "    incorrect_idx = np.where(preds != true_labels)[0][:num_samples // 2]\n",
        "    sample_idx    = np.concatenate([correct_idx, incorrect_idx])\n",
        "\n",
        "    fig, axes = plt.subplots(len(sample_idx), 3,\n",
        "                             figsize=(14, 5 * len(sample_idx)))\n",
        "    fig.suptitle(\"ResNet50 — Grad-CAM Explainability\\n\"\n",
        "                 \"Original  |  Heatmap  |  Overlay\",\n",
        "                 fontsize=14, fontweight='bold', y=1.01)\n",
        "\n",
        "    for row, idx in enumerate(sample_idx):\n",
        "\n",
        "        # Load image\n",
        "        img_original = np.array(\n",
        "            tf.keras.preprocessing.image.load_img(\n",
        "                filepaths[idx], target_size=(224, 224))\n",
        "        )                                                    # uint8 (224,224,3)\n",
        "        img_input = np.expand_dims(img_original / 255.0, axis=0).astype(np.float32)\n",
        "\n",
        "        # Generate Grad-CAM\n",
        "        heatmap   = make_gradcam_heatmap(img_input, conv_model, head_model)\n",
        "        overlayed = overlay_gradcam(img_original, heatmap, alpha=0.4)\n",
        "\n",
        "        # Title info\n",
        "        true_label = class_names[true_labels[idx]]\n",
        "        pred_label = class_names[preds[idx]]\n",
        "        confidence = probs[idx] if preds[idx] == 1 else 1 - probs[idx]\n",
        "        status     = \"✅ Correct\" if preds[idx] == true_labels[idx] else \"❌ Wrong\"\n",
        "        title      = f\"{status}\\nTrue: {true_label} | Pred: {pred_label} ({confidence:.2%})\"\n",
        "\n",
        "        axes[row, 0].imshow(img_original)\n",
        "        axes[row, 0].set_title(\"Original\", fontsize=10)\n",
        "        axes[row, 0].axis('off')\n",
        "\n",
        "        axes[row, 1].imshow(heatmap, cmap='jet')\n",
        "        axes[row, 1].set_title(\"Grad-CAM Heatmap\", fontsize=10)\n",
        "        axes[row, 1].axis('off')\n",
        "\n",
        "        axes[row, 2].imshow(overlayed)\n",
        "        axes[row, 2].set_title(title, fontsize=10,\n",
        "                                color='green' if '✅' in status else 'red')\n",
        "        axes[row, 2].axis('off')\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(\"resnet50_gradcam.png\", dpi=150, bbox_inches='tight')\n",
        "    plt.show()\n",
        "    print(\"\\n✅ Grad-CAM saved as resnet50_gradcam.png\")\n",
        "\n",
        "\n",
        "# ── Run ───────────────────────────────────────────────────────────────────────\n",
        "run_gradcam(resnet_model, conv_model, head_model, test_gen, num_samples=8)"
